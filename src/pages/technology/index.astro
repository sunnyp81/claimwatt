---
import Base from '~/layouts/Base.astro';
import Breadcrumbs from '~/components/Breadcrumbs.astro';
import { TECH } from '~/data/tech';
import { jsonLd, breadcrumbSchema, collectionPageSchema } from '~/lib/schema';

const title = 'Energy Rebates by Technology (Solar, Heat Pump, EV, Battery, Geothermal)';
const description = 'Every federal credit and state rebate stack mapped to the technology you are installing — solar, heat pump, EV, battery, or geothermal heat pump.';
const url = '/technology/';
const today = new Date().toISOString().slice(0, 10);

const items = TECH.map((t) => ({ name: t.name, url: `/technology/${t.slug}/` }));
const schema = jsonLd(
  breadcrumbSchema([{ name: 'Home', url: '/' }, { name: 'Technologies', url }]),
  collectionPageSchema({ url, name: 'Energy Rebates by Technology', description, items }),
);
---
<Base title={title} description={description} schema={schema} lastUpdated={today}>
  <div class="max-w-5xl mx-auto px-4 lg:px-6 py-12">
    <Breadcrumbs items={[{ name: 'Home', url: '/' }, { name: 'Technologies', url }]} />
    <h1 class="text-4xl md:text-5xl font-display leading-tight mb-4">Energy rebates by technology</h1>
    <p class="text-lg text-[var(--color-ink)]/80 leading-relaxed mb-10 max-w-3xl">Each technology has its own federal credit and state-level stack. Pick what you are installing.</p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {TECH.map((t) => (
        <a href={`/technology/${t.slug}/`} class="card hover:border-[var(--color-leaf)] block transition">
          <h2 class="font-display text-xl mb-1">{t.name}</h2>
          <p class="text-sm text-[var(--color-leaf-dark)] font-semibold mb-2">{t.federalAmount}</p>
          <p class="text-sm text-[var(--color-ink)]/70 leading-snug">{t.description.slice(0, 140)}…</p>
        </a>
      ))}
    </div>
  </div>
</Base>

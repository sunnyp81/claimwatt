---
import Base from '~/layouts/Base.astro';
---
<Base title="404 — Page not found | ClaimWatt" description="The page you are looking for does not exist." noindex={true}>
  <div class="max-w-2xl mx-auto px-4 lg:px-6 py-24 text-center">
    <p class="text-sm uppercase tracking-wider text-[var(--color-leaf-dark)] font-semibold mb-3">404</p>
    <h1 class="text-4xl font-display mb-4">Page not found</h1>
    <p class="text-lg text-[var(--color-ink)]/80 leading-relaxed mb-8">That page does not exist on ClaimWatt. Try the federal credit hub, browse by state, or search by technology.</p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a href="/" class="btn btn-primary">Home</a>
      <a href="/federal/" class="btn btn-outline">Federal credits</a>
      <a href="/state/" class="btn btn-outline">By state</a>
    </div>
  </div>
</Base>

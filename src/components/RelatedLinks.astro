---
export interface Props { heading: string; items: { name: string; url: string; meta?: string }[] }
const { heading, items } = Astro.props;
---
<section class="my-12">
  <h2 class="text-xl font-display mb-4">{heading}</h2>
  <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
    {items.map((it) => (
      <li>
        <a href={it.url} class="card hover:border-[var(--color-leaf)] hover:bg-[var(--color-mist)] block transition">
          <span class="font-medium block">{it.name}</span>
          {it.meta && <span class="text-xs text-[var(--color-ink)]/60">{it.meta}</span>}
        </a>
      </li>
    ))}
  </ul>
</section>

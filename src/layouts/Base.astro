---
import '~/styles/global.css';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import SidebarTOC from '~/components/SidebarTOC.astro';
import StickyMobileBar from '~/components/StickyMobileBar.astro';
import ogManifest from '~/data/og-manifest.json';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogSlug?: string;
  noindex?: boolean;
  schema?: string;
  showStickyBar?: boolean;
  lastUpdated?: string;
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogSlug,
  noindex = false,
  schema,
  showStickyBar = false,
  lastUpdated,
} = Astro.props;

const SITE = 'https://claimwatt.com';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, SITE).toString();

const manifestPath = ogSlug && (ogManifest as Record<string, string>)[ogSlug];
const resolvedOg = ogImage ?? manifestPath ?? '/og-default.png';
const ogImageUrl = resolvedOg.startsWith('http') ? resolvedOg : `${SITE}${resolvedOg}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex,follow" />}

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="ClaimWatt" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" />

    {schema && <script type="application/ld+json" set:html={schema} is:inline />}
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:bg-white focus:px-3 focus:py-2 focus:rounded focus:shadow z-50">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
      <SidebarTOC />
    </main>
    {showStickyBar && <StickyMobileBar />}
    <Footer lastUpdated={lastUpdated} />
  </body>
</html>

---
export interface Program {
  name: string;
  amount: string;
  type: string;
  authority: string;
  expiry?: string;
  url?: string;
  href?: string;
}
export interface Props { programs: Program[]; heading?: string }
const { programs, heading = 'Programs available' } = Astro.props;
---
<section class="my-12">
  <h2 class="text-2xl font-display mb-4">{heading}</h2>
  <div class="overflow-x-auto card p-0">
    <table class="cw">
      <thead>
        <tr>
          <th>Program</th>
          <th>Amount</th>
          <th>Type</th>
          <th>Authority</th>
          <th>Deadline</th>
        </tr>
      </thead>
      <tbody>
        {programs.map((p) => (
          <tr>
            <td>
              {p.href ? <a href={p.href} class="text-[var(--color-leaf-dark)] hover:underline font-medium">{p.name}</a> : <span class="font-medium">{p.name}</span>}
            </td>
            <td>{p.amount}</td>
            <td>{p.type}</td>
            <td>{p.authority}</td>
            <td>{p.expiry || 'Ongoing'}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

---
export interface Props { steps: { name: string; text: string }[]; heading?: string }
const { steps, heading = 'How to claim' } = Astro.props;
---
<section class="my-12">
  <h2 class="text-2xl font-display mb-6">{heading}</h2>
  <ol class="space-y-4">
    {steps.map((s, i) => (
      <li class="card flex gap-4">
        <span aria-hidden="true" class="flex-shrink-0 w-9 h-9 rounded-full bg-[var(--color-leaf-dark)] text-white grid place-items-center font-display font-semibold">{i + 1}</span>
        <div>
          <h3 class="text-lg font-semibold mb-1">{s.name}</h3>
          <p class="text-[var(--color-ink)]/80 leading-relaxed">{s.text}</p>
        </div>
      </li>
    ))}
  </ol>
</section>

---
import { TECH } from '~/data/tech';
const navTech = TECH;
---
<header class="border-b border-[var(--color-line)] bg-white/90 backdrop-blur sticky top-0 z-40">
  <div class="max-w-6xl mx-auto px-4 lg:px-6 flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-2 font-display font-semibold text-lg" aria-label="ClaimWatt home">
      <svg width="28" height="28" viewBox="0 0 32 32" aria-hidden="true">
        <circle cx="16" cy="16" r="15" fill="#15803d" />
        <path d="M11 18.5l3 3 7-9" stroke="white" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <span>ClaimWatt</span>
    </a>
    <nav aria-label="Primary" class="hidden md:flex items-center gap-6 text-sm">
      <a href="/federal/" class="hover:text-[var(--color-leaf-dark)]">Federal</a>
      <div class="relative group">
        <button class="hover:text-[var(--color-leaf-dark)] flex items-center gap-1" aria-haspopup="true">By technology
          <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" /></svg>
        </button>
        <div class="invisible opacity-0 group-hover:visible group-hover:opacity-100 transition-opacity absolute top-full right-0 bg-white border border-[var(--color-line)] rounded-lg shadow-lg p-2 min-w-[200px] mt-1">
          {navTech.map((t) => (
            <a href={`/technology/${t.slug}/`} class="block px-3 py-2 rounded hover:bg-[var(--color-mist)] text-sm">{t.name}</a>
          ))}
        </div>
      </div>
      <a href="/state/" class="hover:text-[var(--color-leaf-dark)]">By state</a>
      <a href="/guide/" class="hover:text-[var(--color-leaf-dark)]">Guides</a>
    </nav>
    <a href="/find-rebates/" class="btn btn-primary text-sm">Find my rebates</a>
  </div>
</header>

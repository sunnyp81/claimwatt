---
export interface Props { items: { name: string; url: string }[] }
const { items } = Astro.props;
---
<nav aria-label="Breadcrumb" class="text-sm text-[var(--color-ink)]/60 mb-6">
  <ol class="flex items-center flex-wrap gap-x-2 gap-y-1">
    {items.map((it, i) => (
      <li class="flex items-center gap-2">
        {i < items.length - 1 ? (
          <a href={it.url} class="hover:text-[var(--color-leaf-dark)] hover:underline">{it.name}</a>
        ) : (
          <span aria-current="page" class="text-[var(--color-ink)]">{it.name}</span>
        )}
        {i < items.length - 1 && <span aria-hidden="true">/</span>}
      </li>
    ))}
  </ol>
</nav>

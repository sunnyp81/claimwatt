---
import Base from '~/layouts/Base.astro';
import Breadcrumbs from '~/components/Breadcrumbs.astro';
import { jsonLd, breadcrumbSchema, articleSchema } from '~/lib/schema';

const title = 'US Energy Rebate Glossary: 25C, 25D, 30D, HEEHRA, NEM, SREC';
const description = 'Plain-English glossary of every US energy rebate term — federal credits (25C, 25D, 30D, HEEHRA), tariffs (NEM, VDER, RCP), eligibility (AMI, MAGI), and incentive types.';
const url = '/glossary/';
const today = new Date().toISOString().slice(0, 10);
const schema = jsonLd(
  breadcrumbSchema([{ name: 'Home', url: '/' }, { name: 'Glossary', url }]),
  articleSchema({ url, headline: title, description, datePublished: '2026-01-15', dateModified: today }),
);

const terms = [
  { term: '25C', def: 'IRS Section 25C Energy Efficient Home Improvement Credit. 30% of cost up to $3,200/year for heat pumps, insulation, windows, doors. Through 2032.' },
  { term: '25D', def: 'IRS Section 25D Residential Clean Energy Credit. 30% uncapped on solar, batteries, geothermal, small wind. Carryforward allowed. Through 2032 then phasedown.' },
  { term: '25E', def: 'IRS Section 25E Previously-Owned Clean Vehicle Credit. 30% of sale price up to $4,000 on qualifying used EVs from registered dealers.' },
  { term: '30C', def: 'IRS Section 30C Alternative Fuel Vehicle Refueling Property Credit. 30% up to $1,000 for residential EV chargers in eligible census tracts.' },
  { term: '30D', def: 'IRS Section 30D Clean Vehicle Credit. Up to $7,500 on new EVs, transferable to dealer at point of sale since 2024.' },
  { term: '45L', def: 'IRS Section 45L New Energy Efficient Home Credit. Builder credit ($2,500 ENERGY STAR / $5,000 ZERH) often passed through to buyers.' },
  { term: 'HEEHRA', def: 'High-Efficiency Electric Home Rebate Act. IRA-funded point-of-sale rebate up to $14,000 for income-qualified electrification (heat pumps, induction, panels, wiring).' },
  { term: 'HOMES', def: 'Home Owner Managing Energy Savings Rebate Program. IRA-funded performance-based whole-home retrofit rebate up to $8,000 (income-amplified).' },
  { term: 'AMI', def: 'Area Median Income. HUD-published household income median by county and household size. Used to determine HEEHRA and HOMES eligibility tiers (≤80%, ≤150%).' },
  { term: 'MAGI', def: 'Modified Adjusted Gross Income. Tax measure used for 30D and 25E income caps. For most filers MAGI equals AGI exactly.' },
  { term: 'NEM', def: 'Net Energy Metering. Utility tariff that credits solar customers for excess generation exported to the grid. 1:1 retail-rate NEM is being replaced by avoided-cost or VDER-style tariffs in many states.' },
  { term: 'NEM 3.0', def: 'California successor to net metering since April 2023. Exports valued at avoided-cost rate (~$0.05–$0.15/kWh) instead of retail. Battery storage essentially required for reasonable payback.' },
  { term: 'VDER', def: 'Value of Distributed Energy Resources. New York tariff replacing 1:1 net metering. Stack of credits including energy value, capacity, demand reduction, locational system relief value, environmental.' },
  { term: 'RCP', def: 'Resource Comparison Proxy. Arizona APS tariff for solar export, ~$0.087/kWh. Significantly below retail.' },
  { term: 'SREC', def: 'Solar Renewable Energy Certificate. Tradable certificate generated by solar production. NJ, MA, MD, DC, IL, PA have active SREC markets paying $50–$300/MWh.' },
  { term: 'PBI', def: 'Performance-Based Incentive. Payment based on actual energy production over time. Massachusetts SMART, NY-Sun MW Block, and similar programs use PBI structures.' },
  { term: 'PIN', def: 'Qualified Product Identification Number. Manufacturer-issued identifier required on Form 5695 starting tax year 2025 for heat pumps and HPWHs.' },
  { term: 'ITC', def: 'Investment Tax Credit. Commercial Section 48 ITC is the business equivalent of residential 25D — used by leasing companies and commercial solar installations.' },
  { term: 'PPA', def: 'Power Purchase Agreement. Customer pays for electricity produced at a fixed rate per kWh. Customer does not own the system, so no 25D credit.' },
  { term: 'POS Transfer', def: 'Point-of-sale credit transfer. Mechanic introduced 2024 for 30D and 25E — buyer signs Form 15400, dealer applies credit immediately as cash off price.' },
  { term: 'CEE', def: 'Consortium for Energy Efficiency. Sets multi-tier efficiency standards. Heat pumps must meet highest CEE tier for federal 25C credit eligibility.' },
  { term: 'NEEP', def: 'Northeast Energy Efficiency Partnerships. Maintains the Cold Climate Air Source Heat Pump list — required equipment qualification for state rebates in northern states.' },
  { term: 'AHRI', def: 'Air-Conditioning, Heating, and Refrigeration Institute. Issues certificates confirming equipment performance specifications for tax credit and rebate eligibility.' },
  { term: 'ENERGY STAR', def: 'Federal energy efficiency certification program (EPA + DOE). Most state rebate programs require ENERGY STAR certification on qualifying equipment.' },
  { term: 'ZERH', def: 'DOE Zero Energy Ready Home certification. Higher tier than ENERGY STAR — used for builder 45L credit and higher state rebate tiers.' },
  { term: 'DAC', def: 'Disadvantaged Community. CalEnviroScreen-designated census tracts in California eligible for higher SGIP and DAC-SASH solar rebate tiers.' },
  { term: 'SGIP', def: 'Self-Generation Incentive Program. California battery storage rebate $150–$1,000 per kWh based on tier (General/Equity/Equity Resiliency).' },
  { term: 'WAP', def: 'Weatherization Assistance Program. Federal program providing free weatherization (insulation, air sealing) to low-income households, administered by community action agencies.' },
  { term: 'LIHEAP', def: 'Low Income Home Energy Assistance Program. Federal bill-payment assistance for heating and cooling, administered through state offices.' },
  { term: 'AMT', def: 'Alternative Minimum Tax. Parallel federal tax calculation. 25D and 30D are allowed against AMT; 25C is limited.' },
];
---
<Base title={title} description={description} schema={schema} lastUpdated={today} ogSlug="glossary">
  <article class="max-w-3xl mx-auto px-4 lg:px-6 py-12">
    <Breadcrumbs items={[{ name: 'Home', url: '/' }, { name: 'Glossary', url }]} />
    <h1 class="text-4xl font-display mb-5">Energy rebate glossary</h1>
    <p class="text-lg text-[var(--color-ink)]/85 leading-relaxed mb-10">Plain-English definitions of every federal credit code, IRA program, utility tariff, and eligibility term you will encounter.</p>

    <dl class="space-y-4">
      {terms.map(({ term, def }) => (
        <div class="card">
          <dt class="font-display font-semibold text-lg">{term}</dt>
          <dd class="text-[var(--color-ink)]/85 leading-relaxed mt-1">{def}</dd>
        </div>
      ))}
    </dl>
  </article>
</Base>
